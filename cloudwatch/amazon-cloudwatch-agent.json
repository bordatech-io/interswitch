{
  "agent": {
    "metrics_collection_interval": 60,
    "run_as_user": "root"
  },
  "logs": {
    "logs_collected": {
      "files": {
        "collect_list": [
          {
            "file_path": "/var/log/cba/iso.log",
            "log_group_name": "cba-bridge-iso",
            "log_stream_name": "{hostname}",
            "retention_in_days": 30,
            "timezone": "UTC",
            "multi_line_start_pattern": "^ts=\\d{4}-\\d{2}-\\d{2}T"
          }
        ]
      }
    },
    "force_flush_interval": 5
  }
}
